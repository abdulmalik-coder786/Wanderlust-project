<% layout("/layouts/boilerplate") %>
<body>
    <div class="row mt-3">
        <div class="col-12 col-md-8 offset-md-2">
            <h3>Create a new Listing</h3>
            <form method="POST" action="/listings/create" novalidate class="needs-validation" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="listing[title]" class="form-label">Title:</label>
                    <input type="text" placeholder="Enter title" name="listing[title]" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label for="listing[description]" class="form-label">Description:</label>
                    <textarea type="text" name="listing[description]" class="form-control" required></textarea>
                </div>
                <div class="mb-3">
                    <label for="listing[image]" class="form-label">Image:</label>
                    <input type="file" name="listing[image]" class="form-control">
                </div>
                <div class="row">
                    <div class="mb-3 col-12 col-md-4">
                        <label for="listing[price]" class="form-label">Price:</label>
                        <input type="text" placeholder="Enter price" name="listing[price]" class="form-control" required>

                    </div>
                    <div class="mb-3 col-12 col-md-8">
                        <label for="listing[location]" class="form-label">Location:</label>
                        <input type="text" placeholder="Enter location" name="listing[location]" class="form-control" required>
                    </div>
                </div>
                <div class="mb-3">
                <label for="listing[country]" class="form-label">Country:</label>
                <input type="text" placeholder="Pakistan" name="listing[country]" class="form-control" required>
                </div>
                <br>
                <button class="btn btn-dark add-btn">Add </button>
                
            </form>
            <br>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="/js/new.js"></script>
</body>

<% layout("/layouts/boilerplate") %>
 <script>
        async
        src="https://maps.googleapis.com/maps/api/js?loading=async&key=AIzaSyC-AM7WOh_n7fJbU5AF206-2JRYyu3qFFs8&libraries=maps3d"
    </script>
    <div class="row mt-3 mb-3">
        <div class="col-12 col-md-8 offset-md-2 text-center">
            <h3><%= listing.title %></h3>
        </div>
        <div class="card listing-card col-12 col-md-8 offset-md-2">
            <img src="<%= listing.image.url %>" alt="" class="card-img-top show-img ">
            <div class="card-body ">
                <p class="card-text">Owned by <i> <%= listing.owner.username %> </i></p>
                <p class="card-text"><%= listing.description %></p>
                <p class="card-text">PKR <%= listing.price.toLocaleString() %></p>
                <p class="card-text"> <%= listing.location %></p>
                <p class="card-text"><%= listing.country %></p>
                <% if(currUser && currUser._id.equals(listing.owner._id) ) { %>
                <div class="btns">
                    <form method="GET" action="/listings/<%= listing._id %>/edit">
                        <button class="edit-btn btn ">Edit</button>
                    </form>
                    <form method='POST' action="/listings/<%= listing._id %>?_method=DELETE">
                        <button class="btn btn-dark">Delete</button>
                    </form>
                </div>
               <% } %>
            </div>    
        </div> 
    </div>

    <div class="col-12 col-md-8 offset-md-2 mb-3">
        <% if(currUser) { %>
        <hr>
        <h3>Leave a Review:</h3>
        <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
            <div class="mb-3 mt-3">
                <fieldset class="starability-slot">
                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />

                    <input type="radio" id="rate1" name="review[rating]" value="1" />
                    <label for="rate1">1 star.</label>

                    <input type="radio" id="rate2" name="review[rating]" value="2" />
                    <label for="rate2">2 stars.</label>

                    <input type="radio" id="rate3" name="review[rating]" value="3" />
                    <label for="rate3">3 stars.</label>

                    <input type="radio" id="rate4" name="review[rating]" value="4" />
                    <label for="rate4">4 stars.</label>

                    <input type="radio" id="rate5" name="review[rating]" value="5" />
                    <label for="rate5">5 stars.</label>
                </fieldset>
            </div>
    
            <div class="mb-3 mt-3">
                <label for="review[comments]" class="form-label">Comments</label>
                <textarea cols="30" rows="10" id="comment" name="review[comments]" class="form-control" required></textarea>
                <div class="invalid-feedback">Please add some comments</div>
            </div> 
            
            <button class="btn btn-outline-dark">Submit</button>
        </form>
        <% } %>
            <hr>
        <p>All Reviews</p>
        <div class="row">
            <%for(review of listing.reviews){ %>
                <div class="card col-12 col-md-5 mb-3">
                    <div class="card-body">
                        <p class="card-title">@<%= review.author.username %></p>
                        <p class="starability-result card-text" data-rating="<%= review.rating %>">
                        </p>
                        <p class="card-text"><%= review.comments %></p>

                    </div>
                    <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                        <button class="btn btn-sm btn-dark mb-3 mt-3">
                            Delete
                        </button>
                    </form>
                </div>
            <% } %>
        </div>
    </div>   
 
   